{
  "name": "auto-accept-antigravity",
  "displayName": "Antigravity-AutoAccept",
  "description": "Automatically accept AI agent actions (file edits, terminal commands) in VS Code — zero config, no launch flags needed",
  "version": "0.7.2",
  "icon": "icon.png",
  "publisher": "kaushiksaravanan",
  "author": "Kaushik Saravanan",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaushiksaravanan/Antigravity-AutoAccecpt.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "keywords": [
    "auto-accept",
    "antigravity",
    "agent",
    "ai",
    "automation",
    "auto",
    "accept",
    "vibe-coding"
  ],
  "categories": [
    "Machine Learning",
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autoAcceptAgent.toggle",
        "title": "Auto Accept: Toggle"
      },
      {
        "command": "autoAcceptAgent.start",
        "title": "Auto Accept: Start"
      },
      {
        "command": "autoAcceptAgent.stop",
        "title": "Auto Accept: Stop"
      },
      {
        "command": "autoAcceptAgent.acceptNow",
        "title": "Auto Accept: Accept All Now"
      },
      {
        "command": "autoAcceptAgent.diagnostics",
        "title": "Auto Accept: Run Diagnostics"
      },
      {
        "command": "autoAcceptAgent.showPaywall",
        "title": "Auto Accept: Show RevenueCat Paywall"
      }
    ],
    "keybindings": [
      {
        "command": "autoAcceptAgent.acceptNow",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y"
      }
    ],
    "configuration": {
      "title": "Auto Accept Agent",
      "properties": {
        "autoAcceptAgent.enableCommandPolling": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic polling of accept/approve commands."
        },
        "autoAcceptAgent.pollIntervalMs": {
          "type": "number",
          "default": 800,
          "minimum": 200,
          "maximum": 10000,
          "description": "Interval in milliseconds between polling cycles. Lower = faster auto-acceptance but more CPU. Default: 800ms."
        },
        "autoAcceptAgent.autoConfigureSettings": {
          "type": "boolean",
          "default": true,
          "description": "Automatically configure VS Code/Antigravity settings to skip command approval prompts."
        },
        "autoAcceptAgent.interceptNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Automatically accept primary actions on approval notifications (Run, Allow, Yes)."
        },
        "autoAcceptAgent.blockedCommands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "rm -rf /",
            "format",
            "mkfs",
            "del",
            "del *",
            "rmdir",
            "rd",
            "erase"
          ],
          "description": "A list of strings or command snippets that, if detected near the 'Run' button, will prevent the agent from automatically accepting."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@revenuecat/purchases-js": "^1.26.2",
    "ws": "^8.19.0"
  }
}